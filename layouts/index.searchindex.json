{{- $list := slice -}}
{{- range (where .Site.RegularPages "Section" "posts") -}}
  {{- $image := .Params.image | default "" -}}
  {{- if and $image (not (urls.Parse $image).IsAbs) -}}
    {{- with .Resources.GetMatch $image -}} {{- $image = .RelPermalink -}} {{- end -}}
  {{- end -}}
  {{- $list = $list | append (dict "title" .Title "url" (replace .RelPermalink "index.json" "") "date" (.Date.Format "2006-01-02") "summary" (.Summary | plainify | replaceRE "\\s+" " ") "tags" (.Params.tags | default slice) "series" (.Params.series | default slice) "image" $image "content" (.Plain | replaceRE "\\s+" " ")) -}}
{{- end -}}
{{- $list | jsonify -}}